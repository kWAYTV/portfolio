{
  "name": "ide-portfolio",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:stream": "turbo run dev --ui=stream",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run -F web dev",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "release": "pnpm dlx bumpp -r",
    "update": "pnpm dlx taze -r -w -f"
  },
  "dependencies": {
    "@repo/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@repo/config": "workspace:*",
    "@types/node": "^20.19.37",
    "bumpp": "^10.4.1",
    "husky": "latest",
    "lint-staged": "latest",
    "turbo": "^2.8.20",
    "typescript": "catalog:",
    "ultracite": "7.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
